{
  "expo": {
    "name": "Dofamy",
    "slug": "dofamy",
    "scheme": "dofamy",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F5F3EE",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F5F3EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.dofamy",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Dofamy записывает голосовые планы и отчёты о задачах.",
        "NSCameraUsageDescription": "Dofamy делает якорные фото «до» и «после» для задач."
      }
    },
    "android": {
      "package": "app.dofamy",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешите камеру для якорных фото задач.",
          "microphonePermission": "Разрешите микрофон при записи видео (по желанию)."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Dofamy",
      "shortName": "Dofamy",
      "description": "Фокус, якоря задач и голосовые отчёты",
      "lang": "ru",
      "display": "standalone",
      "themeColor": "#F5F3EE",
      "backgroundColor": "#F5F3EE",
      "orientation": "portrait"
    }
  }
}
