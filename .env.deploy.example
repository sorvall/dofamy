# Скопируйте в .env.deploy и заполните (файл .env.deploy не коммитится).
# Те же значения, что в репозитории urbanscore, если сервер один.

SERVER_HOST=
SERVER_USER=root
SSH_PASSWORD=

# Ключи для сборки PWA (попадают в бандл — те же, что в локальном .env)
EXPO_PUBLIC_YANDEX_SPEECHKIT_API_KEY=
EXPO_PUBLIC_YANDEX_FOLDER_ID=
EXPO_PUBLIC_DEEPSEEK_API_KEY=
# опционально — IAM вместо API-ключа SpeechKit
# EXPO_PUBLIC_YANDEX_IAM_TOKEN=

# опционально
# DEPLOY_PATH=/root/dofamy
# SSH_PORT=22
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=
